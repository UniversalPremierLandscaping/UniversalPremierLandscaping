<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Universal Premier Landscaping</title>

<style>
body {
    margin: 0;
    font-family: Arial, sans-serif;
    background-color: #f4f4f4;
    scroll-behavior: smooth;
}

/* Header */
header {
    background-color: #2e7d32;
    color: white;
    padding: 20px;
    text-align: center;
    opacity: 0;
    transform: translateY(-20px);
    animation: fadeInDown 1s forwards;
}

/* Hero */
.hero {
    background: url('https://images.unsplash.com/photo-1597262975002-c5c3b14bbd62') center/cover no-repeat;
    height: 300px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    color: white;
    text-align: center;
    opacity: 0;
    transform: scale(0.95);
    animation: fadeIn 1.2s forwards;
}

.hero h2 {
    font-size: 32px;
    margin: 0;
    text-shadow: 2px 2px 5px black;
}

.hero p {
    font-size: 18px;
    margin-top: 10px;
}

/* Sections */
.section {
    padding: 40px;
    text-align: center;
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.8s ease-out;
}

/* Gallery */
.gallery {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 15px;
}

.gallery img {
    width: 300px;
    height: 200px;
    object-fit: cover;
    border-radius: 10px;
    transition: transform 0.3s, box-shadow 0.3s;
}

.gallery img:hover {
    transform: scale(1.05);
    box-shadow: 0 8px 20px rgba(0,0,0,0.3);
}

/* Contact */
.contact {
    background-color: #2e7d32;
    color: white;
    padding: 30px;
}

/* Button */
.btn {
    display: inline-block;
    margin-top: 10px;
    padding: 12px 22px;
    background-color: white;
    color: #2e7d32;
    text-decoration: none;
    border-radius: 5px;
    font-weight: bold;
    border: none;
    cursor: pointer;
    transition: all 0.3s;
}

.btn:hover {
    background-color: #ddd;
    transform: translateY(-2px);
}

/* Form */
form input, form textarea {
    width: 100%;
    padding: 10px;
    margin: 10px 0;
    border-radius: 5px;
    border: 1px solid #ccc;
}

/* Footer */
footer {
    background-color: #1b5e20;
    color: white;
    text-align: center;
    padding: 15px;
}

/* Animations */
@keyframes fadeInDown {
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

@keyframes fadeIn {
    to {
        opacity: 1;
        transform: scale(1);
    }
}
</style>
</head>

<body>

<header>
    <h1>Universal Premier Landscaping</h1>
    <p>Professional Landscaping Services</p>
</header>

<div class="hero">
    <h2>Transforming Your Outdoor Space</h2>
    <p>Quality • Reliability • Professional Results</p>
</div>

<div class="section">
    <h2>About Us</h2>
    <p>Universal Premier Landscaping provides reliable and high-quality landscaping services. 
    We take pride in making your yard look clean, beautiful, and professionally maintained.</p>
</div>

<div class="section">
    <h2>Our Services</h2>
    <p>Lawn Care • Yard Cleanups • Tree Trimming • Landscaping Design • Irrigation</p>
</div>

<div class="section">
    <h2>Our Work</h2>
    <div class="gallery">
        <img src="https://images.unsplash.com/photo-1501004318641-b39e6451bec6">
        <img src="https://images.unsplash.com/photo-1599685315640-6d5f4f9fbd9c">
        <img src="https://images.unsplash.com/photo-1560185007-5f0bb1866cab">
        <img src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c">
        <img src="https://images.unsplash.com/photo-1600607687920-4e2a09cf159d">
        <img src="https://images.unsplash.com/photo-1600566753190-17f0baa2a6c3">
    </div>
</div>

<div class="section">
    <h2>Reviews</h2>
    <p>See what our customers are saying about us!</p>
    <a class="btn" href="https://www.yelp.com/biz/universal-premier-landscape-phoenix" target="_blank">
        View Yelp Page
    </a>
</div>

<div class="section">
    <h2>Request a Quote</h2>
    <p>Fill out the form below and we’ll get back to you!</p>

    <form action="https://formspree.io/f/maqlkqaq" method="POST" style="max-width:400px;margin:auto;">
        <input type="text" name="name" placeholder="Your Name" required>
        <input type="tel" name="phone" placeholder="Phone Number" required>
        <textarea name="message" placeholder="What service do you need?" required></textarea>

        <button type="submit" class="btn">Request Quote</button>
    </form>

    <br>
    <a class="btn" href="tel:6023488088">Call Now</a>
</div>

<div class="contact">
    <h2>Contact Us</h2>
    <p>📞 Phone: <a href="tel:6023488088" style="color:white;">602-348-8088</a></p>
    <p>📸 Instagram:</p>
    <a class="btn" href="https://www.instagram.com/universalpremierlandscape?igsh=MWRtMjBoNWd1cmF5YQ==" target="_blank">
        Visit Instagram
    </a>
</div>

<footer>
    <p>© 2026 Universal Premier Landscaping</p>
</footer>

<script>
// Animate sections on scroll
const sections = document.querySelectorAll('.section');
const options = { threshold: 0.1 };

const observer = new IntersectionObserver((entries, observer) => {
    entries.forEach(entry => {
        if(entry.isIntersecting){
            entry.target.style.opacity = 1;
            entry.target.style.transform = "translateY(0)";
            observer.unobserve(entry.target);
        }
    });
}, options);

sections.forEach(section => {
    observer.observe(section);
});
</script>

</body>
</html>